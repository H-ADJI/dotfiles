{
    "layer": "top",
    "position": "top",
    "spacing": 10,
    "margin": 10,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "hyprland/workspaces": {
        "show-special": true,
        "special-visible-only": true,
        "move-to-monitor": true,
        "on-scroll-up": "hyprctl dispatch 'hl.dsp.workspace(\"workspace e+1\")'",
        "on-scroll-down": "hyprctl dispatch 'hl.dsp.workspace(\"workspace e-1\")'",
        "format": "{icon}",
        "format-icons": {
            "special": "Scratch"
        }
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 40
    },
    "modules-center": ["hyprland/submap", "custom/music", "clock"],
    "hyprland/submap": {
        "format": "Mode : [{}]",
        "tooltip": false
    },
    "custom/music": {
        "format": " 🎶  {}",
        "escape": true,
        "interval": 10,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ artist }} - {{ title }}'",
        "on-click": "ghostty --class=cava -e cava",
        "max-length": 40
    },
    "clock": {
        "format": " 󰅐  {:%H:%M  - %A - %d/%m}",
        "tooltip-format": " {:%A %m/%d}\n\n<tt><big>{calendar}</big></tt>",
        "calendar": {
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "modules-right": [
        "network",
        "cpu",
        "memory",
        "bluetooth",
        "pulseaudio#out",
        "pulseaudio#in",
        "backlight",
        "battery",
        "tray",
        "custom/power"
    ],
    "network": {
        "format-disabled": " Disabled",
        "format-wifi": "    {bandwidthDownBits:>} 󰶡 {bandwidthUpBits:>} 󰶣",
        "tooltip-format-wifi": "{essid}",
        "format-ethernet": " {bandwidthDownBits:>} 󰶡 {bandwidthUpBits:>} 󰶣",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}",
        "format-disconnected": " Disconnected",
        "interval": 10,
        "on-click": "ghostty --class=btm -e bandwhich -s"
    },

    "cpu": {
        "interval": 10,
        "format": "CPU : {usage:>3}%",
        "states": {
            "warning": 70,
            "critical": 90
        },
        "on-click": "ghostty --class=btm -e btm"
    },
    "memory": {
        "interval": 10,
        "format": "RAM : {:>3}%",
        "on-click": "ghostty --class=btm -e btm",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },
    "pulseaudio#out": {
        "format": "{volume}%  🎧",
        "format-muted": " ",
        "on-scroll-up": "amixer -q -D pipewire sset Master 5%+",
        "on-scroll-down": "amixer -q -D pipewire sset Master 5%-",
        "on-click": "pavucontrol"
    },
    "pulseaudio#in": {
        "format": "{format_source}",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "on-scroll-up": "amixer -q -D pipewire sset Capture 5%+",
        "on-scroll-down": "amixer -q -D pipewire sset Capture 5%-",
        "on-click": "pavucontrol"
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["󰄰", "󰪞", "󰪟", "󰪠", "󰪡", "󰪢", "󰪣", "󰪤", "󰪥"],
        "tooltip-format": "Backlight (Scroll): {percent:}%",
        "on-scroll-down": "brightnessctl -c backlight set 5%-",
        "on-scroll-up": "brightnessctl -c backlight set +5%"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },
    "bluetooth": {
        "format": "󰂯 {status}",
        "format-on": "󰂯",
        "format-off": "󰂲",
        "format-disabled": "", // an empty format will hide the module
        "format-connected": "{num_connections} 󰂱",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address} - {device_battery_percentage}%",
        "on-click": "ghostty --class=bluetui -e bluetui"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 20
    },
    "custom/power": {
        "format": "⏻",
        "on-click": "wlogout -b 4 -T 400 -B 400",
        "tooltip": false
    }
}
