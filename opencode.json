{
  "$schema": "https://opencode.ai/config.json",
    "permission": {
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow",
            "secrets/**": "deny",
            "ssh/.ssh/*": "deny",
            "ssh/dot-ssh/*": "deny",
            "zsh/dot-zsh_history": "deny",
            "bin/.local/bin/work_setup": "deny",
            "task/dot-taskrc": "deny",
            "leetcode/.leetcode/leetcode.toml": "deny",
            "leetcode/dot-leetcode/leetcode.toml": "deny",
            "scripts/dot-config/scripts/work_setup.sh": "deny",
            "aichat/dot-config/aichat/config.yaml": "deny",
            "qutebrowser/dot-config/qutebrowser/quickmarks": "deny",
            "qutebrowser/dot-config/qutebrowser/bookmarks/*": "deny"
        }
    }
}
