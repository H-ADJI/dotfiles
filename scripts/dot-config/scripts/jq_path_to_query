#!/usr/bin/python

import json
import re
import sys


def is_valid_identifier(key):
    """Check if a string is a valid jq identifier for dot notation."""
    # A valid identifier starts with a letter or underscore,
    # followed by letters, numbers, or underscores.
    return re.match(r"^[a-zA-Z_][a-zA-Z0-9_]*$", key) is not None


def convert_path_to_query(path_array):
    """Converts a jq path array to a query string."""
    query_parts = []
    if not path_array:
        return "."  # Represents the root

    # Handle the first element separately to start with a dot if it's a simple key
    first_element = path_array[0]
    if isinstance(first_element, str) and is_valid_identifier(first_element):
        query_parts.append(f".{first_element}")
    else:
        # Use bracket notation for numbers or complex strings
        query_parts.append(f"[{json.dumps(first_element)}]")

    # Handle the rest of the elements
    for element in path_array[1:]:
        if isinstance(element, int):
            query_parts.append(f"[{element}]")
        elif isinstance(element, str) and is_valid_identifier(element):
            query_parts.append(f".{element}")
        else:
            # Use json.dumps to correctly handle quotes and special characters
            query_parts.append(f"[{json.dumps(element)}]")

    # Join the parts, removing the dot between bracketed elements for cleaner output
    return "".join(query_parts).replace("][", "][")


def process_file(filename):
    """Reads a file line by line and converts each path to a query."""
    try:
        with open(filename, "r") as f:
            for line_num, line in enumerate(f, 1):
                line = line.strip()
                if not line or line[0] == "#":
                    continue
                path_array = json.loads(line)
                jq_query = convert_path_to_query(path_array)
                print(jq_query)
    except FileNotFoundError:
        print(f"Error: File not found at '{filename}'", file=sys.stderr)


if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python convert_paths.py <filename>")
        sys.exit(1)

    input_filename = sys.argv[1]
    process_file(input_filename)
